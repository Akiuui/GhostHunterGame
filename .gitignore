# This file is used to ignore files and folders that are generated by Unity,
# are temporary, or contain user-specific settings.

# Ignore all user-specific files generated by Unity
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uilds/
/[Dd]ownloads/
/[Pp]ackages/
/[Aa]ssets/AssetStoreTools/
/[Aa]ssets/Vuforia/

# Autogenerated files
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.unitypackage
*.booproj

# Visual Studio files
.vs/
.vspscc
.vssscc
.gitattributes

# Rider
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Unity-specific
*.meta

# Other
*/bin/
*/obj/
*/_ReSharper.*/
*/packages/
*/temp/
*/library/
*.pdb
*.pidb
*.pid
*.mdb

# Cache files
*.cache
*.temp
*.tmp
*.log
*.bak
*.orig
*.swp
*.swo

# ProjectSettings files that are often different between users and not necessary to share
ProjectSettings/ProjectVersion.txt
ProjectSettings/PresetManager.asset